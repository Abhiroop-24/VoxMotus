# Flask host and port
APP_HOST=0.0.0.0
APP_PORT=5000

# Camera input
APP_WEBCAM=0
APP_PI_URL=udp://@:8080

# Runtime behavior
APP_BREAK_SECONDS=10
APP_OBSTACLE_AREA=7000
APP_OBSTACLE_ENABLED=true
APP_OBSTACLE_MODE=yolo
APP_OBSTACLE_YOLO_MODEL=yolov8n.pt
APP_OBSTACLE_YOLO_CONF=0.35
APP_OBSTACLE_YOLO_MIN_AREA=0.06
APP_OBSTACLE_ALERT_COOLDOWN=6.0
APP_OBSTACLE_PERSON_ONLY=true
APP_OBSTACLE_IGNORE_PERSON=false
APP_OBSTACLE_DEVICE=cuda
APP_VOICE_COOLDOWN=2.4
APP_MUTE=false
APP_TTS_BACKEND=auto
APP_VOICE_PERSONA=coach
APP_PYTTSX3_VOICE_HINT=
APP_EDGE_TTS_VOICE=en-US-AvaNeural
APP_EDGE_TTS_RATE=+0%
APP_EDGE_TTS_PITCH=+0Hz
APP_PIPER_MODEL=
APP_PIPER_BIN=piper
APP_PIPER_SPEAKER=
APP_RECORD_ANNOTATED=true
APP_OUTPUT_DIR=outputs
APP_OUTPUT_FPS=20

# Pose and dual-camera fusion tuning
APP_POSE_MODEL_LAPTOP=1
APP_POSE_MODEL_PI=2
APP_POSE_MIN_DETECTION_CONF=0.55
APP_POSE_MIN_TRACKING_CONF=0.55
APP_POSE_SMOOTH_ALPHA=0.35
APP_FUSION_MIN_QUALITY=0.18
APP_FEEDBACK_DATASET=feedback_dataset.json

# Optional safe rephrasing (cache-first, non-blocking; never controls logic)
APP_REPHRASE_ENABLED=false
APP_REPHRASE_PROVIDER=groq
APP_REPHRASE_MODEL=llama-3.1-8b-instant
APP_REPHRASE_API_KEY=
APP_REPHRASE_API_BASE=

# Dataset-trained activity classifier and capture controls
APP_AI_WEIGHTS_PATH=models/activity_weights.json
APP_AI_CONFIDENCE=0.82
APP_COLLECT_TRAINING_DATA=false
APP_TRAINING_DATA_DIR=outputs/datasets
APP_TRAINING_FLUSH_EVERY=250

# Pi auto-start over SSH
PI_AUTO_START=true
PI_HOST=10.42.0.116
PI_PORT=22
PI_USER=abhiroop
PI_PASSWORD=
PI_START_CMD=cd ~ && ./start_cam.sh > /tmp/drishti_stream.log 2>&1 &
